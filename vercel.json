{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/backend/:path*", "destination": "https://stackpro-api-production.up.railway.app/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
